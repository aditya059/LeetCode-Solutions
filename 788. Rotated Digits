class Solution {
public:
    int rotatedDigits(int n) {
        int ans = 0;
        for(int i = 1; i <= n; i++) {
            bool valid = true, diff = false;
            for(int j = i; j > 0 && valid; j /= 10) {
                int d = j % 10;
                if(d == 2 || d == 5 || d == 6 || d == 9) {
                    diff = true;
                } else if(d == 3 || d == 4 || d == 7) {
                    valid = false;
                    break;
                }
            }
            if(valid && diff) {
                ans++;
            }
        }
        return ans;
    }
};
