class Solution {
public:
    int furthestDistanceFromOrigin(string moves) {
        int diff = 0, underscore = 0;
        for(int i = 0; i < moves.size(); i++) {
            if(moves[i] == 'L') diff++;
            else if(moves[i] == 'R') diff--;
            else underscore++;
        }
        return abs(diff) + underscore;
    }
};
