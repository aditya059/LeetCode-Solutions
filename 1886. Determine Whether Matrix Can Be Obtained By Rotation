class Solution {
    vector<vector<int>> rotateMatrix(vector<vector<int>>& mat) {
        int n = mat.size();
        vector<vector<int>> temp(n, vector<int>(n));
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < n; j++) {
                temp[j][n - i - 1] = mat[i][j];
            }
        }
        return temp;
    }
public:
    bool findRotation(vector<vector<int>>& mat, vector<vector<int>>& target) {
        for(int i = 0; i < 4; i++) {
            mat = rotateMatrix(mat);
            if(mat == target) {
                return true;
            }
        }    
        return false;
    }
};
