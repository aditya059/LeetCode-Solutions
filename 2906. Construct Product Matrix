class Solution {
    const int MOD = 12345;
public:
    vector<vector<int>> constructProductMatrix(vector<vector<int>>& grid) {
        int m = grid.size(), n = grid[0].size();
        vector<int> prefix(m * n + 1);
        long prod = 1, k = 0;
        prefix[k] = 1;
        for(int i = 0; i < m; i++) {
            for(int j = 0; j < n; j++) {
                prod = (prod * grid[i][j]) % MOD;
                prefix[++k] = prod;
            }
        }
        vector<int> suffix(m * n + 1);
        prod = 1, k = m * n;
        suffix[k] = 1;
        for(int i = m - 1; i >= 0; i--) {
            for(int j = n - 1; j >= 0; j--) {
                prod = (prod * grid[i][j]) % MOD;
                suffix[--k] = prod;
            }
        }
        for(int i = 0; i < m; i++) {
            for(int j = 0; j < n; j++) {
                int index = n * i + j;
                grid[i][j] = (prefix[index] * suffix[index + 1]) % MOD;
            }
        }
        return grid;
    }
};
