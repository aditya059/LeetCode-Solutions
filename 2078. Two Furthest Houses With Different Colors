class Solution {
public:
    int maxDistance(vector<int>& colors) {
        int n = colors.size();
        for(int i = 0; i < n; i++) {
            if(colors[i] != colors[n - 1]) {
                return n - i - 1;
            } 
            if(colors[0] != colors[n - i - 1]) {
                return n - i - 1;
            }
        }
        return -1;
    }
};
