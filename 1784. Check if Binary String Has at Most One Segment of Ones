class Solution {
public:
    bool checkOnesSegment(string s) {
        int len = 0, count = 0;
        for(int i = 0; i < s.length(); i++) {
            if(s[i] == '1') {
                len++;
                if(count == 2) return false;
            } else {
                count += len > 0;
                len = 0;
            }
        }
        count += len > 0;
        return count == 1;
    }
};
