class Solution {
public:
    vector<int> solveQueries(vector<int>& nums, vector<int>& queries) {
        int n = nums.size();
        vector<int> lindex(n), rindex(n);
        unordered_map<int, int> lpos, rpos;
        for(int i = -n; i < n; i++) {
            if(i >= 0) {
                lindex[i] = lpos[nums[i]];
            }
            lpos[nums[(i + n) % n]] = i;
        }
        for(int i = 2 * n - 1; i >= 0; i--) {
            if(i < n) {
                rindex[i] = rpos[nums[i]];
            }
            rpos[nums[i % n]] = i;
        }
        int qSize = queries.size();
        vector<int> ans(qSize);
        for(int i = 0; i < qSize; i++) {
            int q = queries[i]; 
            if(q - lindex[q] == n) {
                ans[i] = -1;
            } else {
                ans[i] = min(abs(q - lindex[q]), abs(rindex[q] - q));
            }
        }
        return ans;
    }
};
