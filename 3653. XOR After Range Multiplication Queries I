class Solution {
    const int MOD = 1e9 + 7;
public:
    int xorAfterQueries(vector<int>& nums, vector<vector<int>>& queries) {
        for(vector<int> &query: queries) {
            for(int i = query[0]; i <= query[1]; i += query[2]) {
                nums[i] = (nums[i] * 1L * query[3]) % MOD;
            }
        }   
        int ans = 0;
        for(int i = 0; i < nums.size(); i++) {
            ans = ans xor nums[i];
        }
        return ans;
    }
};
