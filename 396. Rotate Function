class Solution {
public:
    int maxRotateFunction(vector<int>& nums) {
        int sum = accumulate(nums.begin(), nums.end(), 0);
        int f = 0, n = nums.size();
        for(int i = 0; i < n; i++) {
            f += i * nums[i];
        }
        int ans = f;
        for(int i = 1; i < n; i++) {
            f = f + sum - n * nums[n - i];
            ans = max(ans, f);
        }
        return ans;
    }
};
