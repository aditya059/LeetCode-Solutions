class Solution {
    const int MOD = 1e9 + 7;
    int fastExp(int x, int n) {
        if(n == 0) return 1;
        else if(n == 1) return x;
        int y = fastExp(x, n / 2);
        y = (y * 1LL * y) % MOD;
        if(n % 2) y = (y * 1LL * x) % MOD;
        return y; 
    }
public:
    int xorAfterQueries(vector<int>& nums, vector<vector<int>>& queries) {
        int n = nums.size();
        int m = sqrt(n);
        unordered_map<int, vector<int>> Map;
        for(int i = 0; i < queries.size(); i++) {
            vector<int> &query = queries[i];
            if(query[2] >= m) {
                for(int j = query[0]; j <= query[1]; j += query[2]) {
                    nums[j] = (nums[j] * 1LL * query[3]) % MOD;
                }
            } else {
                Map[query[2]].push_back(i);
            }
        }
        
        for(auto iter: Map) {
            vector<int> prefix(n + m, 1);
            int k = iter.first;
            vector<int> &indexes = iter.second;
            for(int i: indexes) {
                vector<int> &q = queries[i];
                int l = q[0], r = q[1], v = q[3];
                prefix[l] = (prefix[l] * 1LL * v) % MOD;
                int R = ((r - l) / k + 1) * k + l;
                prefix[R] = (prefix[R] * 1LL * fastExp(v, MOD - 2)) % MOD;
            }
            for(int i = k; i < n; i++) {
                prefix[i] = (prefix[i] * 1LL * prefix[i - k]) % MOD;
            }
            for(int i = 0; i < n; i++) {
                nums[i] = (nums[i] * 1LL * prefix[i]) % MOD;
            }
        }
        int ans = 0;
        for(int i = 0; i < n; i++) {
            ans = ans xor nums[i];
        }
        return ans;
    }
};
