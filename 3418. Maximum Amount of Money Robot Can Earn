class Solution {
public:
    int maximumAmount(vector<vector<int>>& coins) {
        int m = coins.size(), n = coins[0].size();
        vector<vector<vector<int>>> DP(m, vector<vector<int>>(n, vector<int>(3, INT_MIN/2)));
        DP[0][0][0] = coins[0][0];
        DP[0][0][1] = DP[0][0][2] = max(0, coins[0][0]);
        for(int j = 1; j < n; j++) {
            DP[0][j][0] = DP[0][j - 1][0] + coins[0][j];
            for(int k = 1; k < 3; k++) {
                DP[0][j][k] = max(DP[0][j - 1][k] + coins[0][j], DP[0][j - 1][k - 1]);
            }
        }
        for(int i = 1; i < m; i++) {
            DP[i][0][0] = DP[i - 1][0][0] + coins[i][0];
            for(int k = 1; k < 3; k++) {
                DP[i][0][k] = max(DP[i - 1][0][k] + coins[i][0], DP[i - 1][0][k - 1]);
            }
        }
        for(int i = 1; i < m; i++) {
            for(int j = 1; j < n; j++) {
                DP[i][j][0] = max(DP[i - 1][j][0], DP[i][j - 1][0]) + coins[i][j];
                for(int k = 1; k < 3; k++) {
                    DP[i][j][k] = max(max(DP[i - 1][j][k], DP[i][j - 1][k]) + coins[i][j], max(DP[i - 1][j][k - 1], DP[i][j - 1][k - 1]));
                }
            }
        }
        return DP[m - 1][n - 1][2];
    }
};
