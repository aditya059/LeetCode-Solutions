class Solution {
public:
    int numberOfSubmatrices(vector<vector<char>>& grid) {
        int m = grid.size(), n = grid[0].size(), ans = 0;
        vector<int> totalX(n), totalY(n);
        for(int i = 0; i < m; i++) {
            int currRowX = 0, currRowY = 0;
            for(int j = 0; j < n; j++) {
                currRowX += grid[i][j] == 'X';
                currRowY += grid[i][j] == 'Y';
                totalX[j] += currRowX;
                totalY[j] += currRowY;
                ans += totalX[j] && totalX[j] == totalY[j];
            }
        }
        return ans;
    }
};
